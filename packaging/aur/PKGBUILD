# Maintainer: Daniel <daniel@example.com>

pkgname=widdgyy-git
pkgver=r41.g8134549
pkgrel=1
pkgdesc="GTK4 layer-shell desktop widget renderer with text, media and layout stickers"
arch=('x86_64')
url="https://github.com/dantejvar28/widdgyy"
license=('GPL-3.0-or-later')
depends=(
  'python'
  'python-gobject'
  'python-cairo'
  'python-commentjson'
  'python-requests'
  'gtk4'
  'gtk4-layer-shell'
  'gstreamer'
  'gst-plugins-base'
  'gst-plugins-good'
)
makedepends=(
  'git'
  'cargo'
  'rust'
)
provides=('widdgyy')
conflicts=('widdgyy')
source=("${pkgname}::git+https://github.com/dantejvar28/widdgyy.git")
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/${pkgname}"
  printf "r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "${srcdir}/${pkgname}/native/video"
  cargo build --release
}

package() {
  cd "${srcdir}/${pkgname}"

  install -dm755 "${pkgdir}/usr/share/widdgyy"
  cp -r core "${pkgdir}/usr/share/widdgyy/"
  cp -r layouts "${pkgdir}/usr/share/widdgyy/"
  cp -r media "${pkgdir}/usr/share/widdgyy/"
  cp -r stickers "${pkgdir}/usr/share/widdgyy/"
  cp -r utils "${pkgdir}/usr/share/widdgyy/"
  if [[ -d assets ]]; then
    cp -r assets "${pkgdir}/usr/share/widdgyy/"
  fi
  install -m644 main.py "${pkgdir}/usr/share/widdgyy/main.py"
  install -m644 README.md "${pkgdir}/usr/share/widdgyy/README.md"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  install -dm755 "${pkgdir}/usr/share/widdgyy/native/video"
  install -m644 native/video/target/release/libwiddgyy_video.so \
    "${pkgdir}/usr/share/widdgyy/native/video/widdgyy_video.so"

  install -Dm755 packaging/aur/widdgyy.sh "${pkgdir}/usr/bin/widdgyy"
}
